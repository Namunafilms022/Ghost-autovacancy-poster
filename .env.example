# Ghost AutoVacancy Poster — Environment Variables
# Copy to .env and fill in your values

# Dashboard basic auth
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme123

# Facebook publisher
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_GROUP_IDS=
FACEBOOK_API_VERSION=v18.0

# Poster contact info
POSTER_REPLACE_PHONE=9851001001
POSTER_REPLACE_EMAIL=ghost@jobposter.com

# Database
DATABASE_PATH=./ghost_vacancies.db

# Telegram alert (worker failures)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# App
APP_ENVIRONMENT=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO
